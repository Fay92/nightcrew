#!/usr/bin/env python3
"""Fake Claude Code CLI for ccnight integration tests.

Behaviour is selected with environment variables:

  FAKE_CLAUDE_MODE        ok | limit_json | limit_text | garbage   (default: ok)
  FAKE_CLAUDE_SESSION_ID  session id to advertise (default: fake-sess-0001)
  FAKE_CLAUDE_LIMIT_TEXT  limit message for the limit modes
  FAKE_CLAUDE_ARGS_FILE   when set, argv is dumped there as JSON so tests can
                          assert exactly how ccnight invoked the CLI

Scenarios:
  ok          valid stream-json: init -> assistant -> result(success), exit 0
  limit_json  init, then an error result whose text is a limit message, exit 1
  limit_text  plain-text limit message on stdout (old-CLI style), exit 1
  garbage     non-JSON noise on stdout and stderr, exit 2
"""

import json
import os
import sys


def emit(obj):
    print(json.dumps(obj), flush=True)


def main():
    argv = sys.argv[1:]
    args_file = os.environ.get("FAKE_CLAUDE_ARGS_FILE")
    if args_file:
        with open(args_file, "w", encoding="utf-8") as fh:
            json.dump(argv, fh)

    mode = os.environ.get("FAKE_CLAUDE_MODE", "ok")
    session_id = os.environ.get("FAKE_CLAUDE_SESSION_ID", "fake-sess-0001")

    if mode == "garbage":
        print("\x89PNG\r\n\x1a\n not json at all %%%")
        print("][}{ truncated nonsense")
        sys.stderr.write("fake-claude: internal explosion\n")
        return 2

    if mode == "limit_text":
        # Old-style plain text wall message, default uses pipe+epoch format.
        text = os.environ.get(
            "FAKE_CLAUDE_LIMIT_TEXT", "Claude AI usage limit reached|1893456000"
        )
        print(text)
        return 1

    emit(
        {
            "type": "system",
            "subtype": "init",
            "session_id": session_id,
            "cwd": os.getcwd(),
            "model": "claude-fake",
            "tools": [],
        }
    )

    if mode == "limit_json":
        text = os.environ.get(
            "FAKE_CLAUDE_LIMIT_TEXT", "5-hour limit reached ∙ resets 3am"
        )
        emit(
            {
                "type": "result",
                "subtype": "error_during_execution",
                "is_error": True,
                "result": text,
                "session_id": session_id,
            }
        )
        return 1

    emit(
        {
            "type": "assistant",
            "message": {
                "role": "assistant",
                "content": [{"type": "text", "text": "All done."}],
            },
            "session_id": session_id,
        }
    )
    emit(
        {
            "type": "result",
            "subtype": "success",
            "is_error": False,
            "result": "All done.",
            "duration_ms": 120,
            "num_turns": 1,
            "session_id": session_id,
            "total_cost_usd": 0.0,
        }
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
